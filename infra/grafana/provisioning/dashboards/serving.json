{
  "title": "vLLM serving",
  "uid": "vllm-serving",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "tags": ["vllm", "production"],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 10,
      "title": "Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "E2E Request Latency (P95/P50)",
      "description": "End-to-end request latency percentiles.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(vllm_e2e_request_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95 E2E"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum(rate(vllm_e2e_request_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P50 E2E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "TTFT & Inter-Token Latency (P95)",
      "description": "Time to First Token (TTFT) and Inter-Token Latency (TPOT).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(vllm_time_to_first_token_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95 TTFT"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(vllm_inter_token_latency_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95 ITL"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 20,
      "title": "Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token Throughput (Tokens/s)",
      "description": "Rate of prompt and generation tokens processed.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(vllm_prompt_tokens_total[2m]))",
          "legendFormat": "Prompt Tokens"
        },
        {
          "refId": "B",
          "expr": "sum(rate(vllm_generation_tokens_total[2m]))",
          "legendFormat": "Generation Tokens"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests State & Health",
      "description": "Requests running, waiting (queue), and success rate.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm_num_requests_running",
          "legendFormat": "Running"
        },
        {
          "refId": "B",
          "expr": "vllm_num_requests_waiting",
          "legendFormat": "Waiting"
        },
        {
          "refId": "C",
          "expr": "sum(rate(vllm_request_success_total[2m])) by (finished_reason)",
          "legendFormat": "Success ({{finished_reason}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 30,
      "title": "KV Cache",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GPU KV Cache Usage Factor",
      "description": "A scale from 0.0 to 1.0. If this line hits 1.0, VRAM cache blocks are full.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "vllm_kv_cache_usage_perc",
          "legendFormat": "GPU KV Cache %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Prefix Cache Efficiency",
      "description": "Hit rate of the prefix cache.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(vllm_prefix_cache_hits_total[1m]) / rate(vllm_prefix_cache_queries_total[1m])",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 }
        }
      }
    }
  ]
}